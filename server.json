{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Piccolo123/url-manager-mcp",
  "description": "Agent-first web bookmark management with auto-registration, categories, tags, and shared collections.",
  "repository": {
    "url": "https://github.com/Piccolo123/url-manager-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "url-manager-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "command": "python",
      "args": ["server.py"],
      "environmentVariables": [
        {
          "description": "URL Manager API endpoint",
          "isRequired": false,
          "format": "string",
          "name": "FOOTPRINTS_ENDPOINT",
          "default": "https://ai.ocean94.com"
        },
        {
          "description": "URL Manager API token. Leave empty for agent-first auto-registration.",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "FOOTPRINTS_TOKEN"
        }
      ]
    }
  ]
}
